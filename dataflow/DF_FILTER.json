{
	"name": "DF_FILTER",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_READ_CSV",
						"type": "DatasetReference"
					},
					"name": "SourceDataset"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_CSV_TARGET",
						"type": "DatasetReference"
					},
					"name": "sinkdata"
				}
			],
			"transformations": [
				{
					"name": "filterQuaterly"
				}
			],
			"scriptLines": [
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     limit: 1000,",
				"     ignoreNoFilesFound: false) ~> SourceDataset",
				"SourceDataset filter(byName('quarter') == 'Q1') ~> filterQuaterly",
				"filterQuaterly sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkdata"
			]
		}
	}
}